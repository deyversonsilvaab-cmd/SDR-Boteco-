# Chave da OpenAI (OBRIGATÓRIA) - pegue em https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Modelo usado (opcional) - padrão: gpt-4o
OPENAI_MODEL=gpt-4o

# Segredo do webhook (opcional, recomendado) - protege o endpoint de chamadas não autorizadas
WEBHOOK_SECRET=

# Nome do negócio (opcional) - usado só se a base de conhecimento não carregar
BUSINESS_NAME=Sr. Boteco Limeira
